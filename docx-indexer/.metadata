{
  "name": "docx-indexer",
  "version": "1.2.0",
  "description": "Global document indexing system with append-only JSON index, UUID identity, SHA256 hashing, structural telemetry, and Stage 2.2 v1 manual-first enrichment (summary + keywords).",
  "status": "production",
  "author": "Xavier (Claude Opus 4.6) + Jimmy",
  "audited_by": "Magneto (Claude Opus 4.6)",
  "created": "2026-03-05",
  "updated": "2026-03-11",
  "type": "workspace-tool",
  "auto_load": false,
  "triggers": {
    "scan": [
      "run docx-indexer scan",
      "index the workspace",
      "scan documents",
      "atualiza o indice",
      "roda o scan",
      "update the index"
    ],
    "query": [
      "find file in index",
      "where is file",
      "acha no indice",
      "onde esta o arquivo",
      "consulta o indice",
      "check the document index",
      "indice de documentos",
      "indice de arquivos",
      "list files",
      "how many files",
      "file summary",
      "summary do arquivo",
      "keywords do arquivo"
    ],
    "validate": [
      "validate the index",
      "check index integrity",
      "valida o indice"
    ],
    "dry-run": [
      "dry-run the index",
      "preview scan",
      "roda um dry-run",
      "what changed since last scan"
    ],
    "export": [
      "export index to markdown",
      "exporta o indice"
    ],
    "enrich": [
      "enrich the index",
      "enriquece o indice",
      "generate summaries",
      "generate keywords"
    ]
  },
  "settings": {
    "technical_workspace": "C:\\ai\\_skills\\docx-indexer",
