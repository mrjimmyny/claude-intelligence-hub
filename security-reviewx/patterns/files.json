{
  "version": "1.0.0",
  "module": "FILE_SCAN",
  "patterns": [
    {
      "id": "FILE-ENV-001",
      "name": "Environment File",
      "regex": "^\\.env(\\..*)?$",
      "severity": "CRITICAL",
      "description": "Environment file detected — likely contains secrets",
      "category": "dangerous_file",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": [".env.example", ".env.template", ".env.sample"],
      "remediation": "Add to .gitignore. Remove from repo. Use .env.example with placeholder values.",
      "compliance": ["SOC2"],
      "enabled": true
    },
    {
      "id": "FILE-KEY-001",
      "name": "Private Key File",
      "regex": "\\.(pem|key|p12|pfx|keystore|jks)$",
      "severity": "CRITICAL",
      "description": "Private key or keystore file detected",
      "category": "dangerous_file",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Remove from repo immediately. Store in secure key management system. Regenerate if exposed.",
      "compliance": ["SOC2", "ISO27001", "PCI-DSS"],
      "enabled": true
    },
    {
      "id": "FILE-CRED-001",
      "name": "Credential File",
      "regex": "(credentials|service-account.*|client_secret.*)\\.json$",
      "severity": "CRITICAL",
      "description": "Credential or service account file detected",
      "category": "dangerous_file",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": ["credentials.example.json"],
      "remediation": "Remove from repo. Add pattern to .gitignore. Use environment variables or secret manager.",
      "compliance": ["SOC2", "ISO27001"],
      "enabled": true
    },
    {
      "id": "FILE-SSH-001",
      "name": "SSH Key/Config File",
      "regex": "(known_hosts|authorized_keys|id_rsa.*|id_ed25519.*|id_ecdsa.*)$",
      "severity": "CRITICAL",
      "description": "SSH private key or configuration file detected",
      "category": "dangerous_file",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Remove from repo immediately. Regenerate SSH key pair if exposed.",
      "compliance": ["SOC2", "ISO27001"],
      "enabled": true
    },
    {
      "id": "FILE-DB-001",
      "name": "Database File",
      "regex": "\\.(sqlite|sqlite3|db|mdb|accdb)$",
      "severity": "HIGH",
      "description": "Database file detected — may contain sensitive data",
      "category": "dangerous_file",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Remove from repo. Add to .gitignore. Use database server for shared data.",
      "compliance": ["GDPR", "LGPD"],
      "enabled": true
    },
    {
      "id": "FILE-DUMP-001",
      "name": "Database Dump",
      "regex": "\\.(sql|dump|bson)$",
      "severity": "HIGH",
      "description": "Database dump file detected — likely contains data",
      "category": "dangerous_file",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": ["schema.sql", "migration", "create_table"],
      "remediation": "Remove from repo. Database dumps should never be version-controlled.",
      "compliance": ["GDPR", "LGPD"],
      "enabled": true
    },
    {
      "id": "FILE-BAK-001",
      "name": "Backup File",
      "regex": "\\.(bak|old|orig|backup|save)$",
      "severity": "LOW",
      "description": "Backup file detected — may contain outdated or sensitive data",
      "category": "cleanup",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Delete backup file. Add pattern to .gitignore.",
      "compliance": [],
      "enabled": true
    },
    {
      "id": "FILE-SWAP-001",
      "name": "Editor Swap File",
      "regex": "\\.(swp|swo|~)$|\\.#",
      "severity": "LOW",
      "description": "Editor swap/temp file detected",
      "category": "cleanup",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Delete swap file. Add *.swp, *~ to .gitignore.",
      "compliance": [],
      "enabled": true
    },
    {
      "id": "FILE-OS-001",
      "name": "OS Artifact",
      "regex": "(Thumbs\\.db|\\.DS_Store|desktop\\.ini)$",
      "severity": "LOW",
      "description": "OS-generated artifact file detected",
      "category": "cleanup",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Delete and add to .gitignore.",
      "compliance": [],
      "enabled": true
    },
    {
      "id": "FILE-BIN-001",
      "name": "Large Binary File",
      "regex": "__size_check__",
      "severity": "MEDIUM",
      "description": "Binary file larger than 50MB not in assets directory",
      "category": "binary",
      "file_types": ["__size__"],
      "exclude_paths": ["assets/", "releases/"],
      "false_positive_hints": [],
      "remediation": "Use Git LFS for large binaries, or remove from repo.",
      "compliance": [],
      "enabled": true
    },
    {
      "id": "FILE-BIN-002",
      "name": "Executable File",
      "regex": "\\.(exe|dll|so|dylib|com|bat|cmd)$",
      "severity": "HIGH",
      "description": "Compiled executable or library in repository",
      "category": "binary",
      "file_types": ["__filename__"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Remove executable. Build from source instead of committing binaries.",
      "compliance": [],
      "enabled": true
    },
    {
      "id": "FILE-GI-001",
      "name": "Missing .gitignore: .env",
      "regex": "__gitignore_check__",
      "severity": "HIGH",
      "description": ".gitignore does not contain .env pattern",
      "category": "gitignore",
      "file_types": [".gitignore"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Add .env and .env.* to .gitignore.",
      "compliance": ["SOC2"],
      "enabled": true
    },
    {
      "id": "FILE-GI-002",
      "name": "Missing .gitignore: *.pem",
      "regex": "__gitignore_check__",
      "severity": "HIGH",
      "description": ".gitignore does not contain *.pem pattern",
      "category": "gitignore",
      "file_types": [".gitignore"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Add *.pem to .gitignore.",
      "compliance": ["SOC2"],
      "enabled": true
    },
    {
      "id": "FILE-GI-003",
      "name": "Missing .gitignore: *.key",
      "regex": "__gitignore_check__",
      "severity": "HIGH",
      "description": ".gitignore does not contain *.key pattern",
      "category": "gitignore",
      "file_types": [".gitignore"],
      "exclude_paths": [],
      "false_positive_hints": [],
      "remediation": "Add *.key to .gitignore.",
      "compliance": ["SOC2"],
      "enabled": true
    }
  ]
}
