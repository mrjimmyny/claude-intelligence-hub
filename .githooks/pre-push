#!/usr/bin/env bash
# ============================================================
# security-reviewx pre-push hook - QUICK mode scan
#
# Install:
#   For repos with .githooks/: cp this file to .githooks/pre-push
#   For repos without: cp this file to .git/hooks/pre-push
#   Always: chmod +x the installed copy
#   Always: sed -i 's/\r$//' the installed copy (Windows CRLF fix)
#
# Skip: git push --no-verify (not recommended)
#
# Behavior:
#   - Scans commits being pushed for sensitive data
#   - CRITICAL findings -> BLOCK push (exit 1)
#   - HIGH/MEDIUM/LOW -> WARN but allow push (exit 0)
#   - No findings -> PASS (exit 0)
# ============================================================

set -uo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}security-reviewx pre-push scan (QUICK mode)${NC}"
echo "================================================"

# Read push info from stdin (pre-push hook protocol)
RANGE=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    MERGE_BASE=$(git merge-base main "$local_sha" 2>/dev/null || echo "")
    if [ -n "$MERGE_BASE" ]; then
      RANGE="$MERGE_BASE..$local_sha"
    else
      RANGE="$local_sha"
    fi
  else
    RANGE="$remote_sha..$local_sha"
  fi
done

if [ -z "$RANGE" ]; then
  echo -e "${GREEN}PASS: Nothing to scan.${NC}"
  exit 0
fi

CRITICAL_COUNT=0
HIGH_COUNT=0
MEDIUM_COUNT=0

# M1: SECRET_SCAN
echo -n "M1 SECRET_SCAN... "
for pattern in \
  'sk-ant-api[0-9]{2}-[A-Za-z0-9_-]{20,}' \
  'AKIA[0-9A-Z]{16}' \
  'ghp_[A-Za-z0-9]{36}' \
  'sk-[A-Za-z0-9]{32,}' \
  '-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----'; do
  count=$(git diff "$RANGE" -- ':!.githooks/' ':!*/patterns/' ':!*/pre-push-hook.sh' ':!*/tests/' 2>/dev/null | grep -E "$pattern" 2>/dev/null | grep -v 'EXAMPLE' | grep -v 'placeholder' | grep -v 'test-key' | grep -v 'FAKE' | grep -v 'false_positive' | grep -v 'pre-push' | grep -v 'patterns/' | grep -v 'regex' | wc -l)
  count=$((count + 0))
  if [ "$count" -gt 0 ]; then
    CRITICAL_COUNT=$((CRITICAL_COUNT + count))
  fi
done
if [ "$CRITICAL_COUNT" -gt 0 ]; then
  echo -e "${RED}FAIL ($CRITICAL_COUNT critical)${NC}"
else
  echo -e "${GREEN}PASS${NC}"
fi

# M2: PII_SCAN
echo -n "M2 PII_SCAN... "
pii_count=$(git diff "$RANGE" -- ':!.githooks/' ':!*/patterns/' ':!*/pre-push-hook.sh' ':!*/tests/' 2>/dev/null | grep -E '[0-9]{3}\.[0-9]{3}\.[0-9]{3}-[0-9]{2}' 2>/dev/null | grep -v '000\.000\.000-00' | grep -v '111\.111\.111-11' | grep -v 'false_positive' | grep -v 'pre-push' | grep -v 'patterns/' | grep -v 'regex' | wc -l)
pii_count=$((pii_count + 0))
if [ "$pii_count" -gt 0 ]; then
  HIGH_COUNT=$((HIGH_COUNT + pii_count))
  echo -e "${YELLOW}WARN ($pii_count high)${NC}"
else
  echo -e "${GREEN}PASS${NC}"
fi

# M3: FILE_SCAN
echo -n "M3 FILE_SCAN... "
file_count=$(git diff --name-only "$RANGE" 2>/dev/null | grep -E '\.(pem|key|p12|pfx)$' | grep -v 'tests/' | wc -l)
env_count=$(git diff --name-only "$RANGE" 2>/dev/null | grep -E '(^|/)\.env$' | grep -v 'tests/' | wc -l)
dangerous=$((file_count + env_count))
if [ "$dangerous" -gt 0 ]; then
  CRITICAL_COUNT=$((CRITICAL_COUNT + dangerous))
  echo -e "${RED}FAIL ($dangerous dangerous files)${NC}"
else
  echo -e "${GREEN}PASS${NC}"
fi

# M4: PATH_SCAN
echo -n "M4 PATH_SCAN... "
path_count=$(git diff "$RANGE" -- ':!.githooks/' ':!*/patterns/' ':!*/pre-push-hook.sh' ':!*/tests/' 2>/dev/null | grep -E '[A-Z]:\\Users\\[^\\{[:space:]]+\\' 2>/dev/null | grep -v '{USERNAME}' | grep -v '{USER}' | grep -v '{HOME}' | grep -v 'example' | grep -v 'false_positive' | grep -v 'pre-push' | grep -v 'patterns/' | grep -v 'regex' | wc -l)
path_count=$((path_count + 0))
if [ "$path_count" -gt 0 ]; then
  MEDIUM_COUNT=$((MEDIUM_COUNT + path_count))
  echo -e "${YELLOW}WARN ($path_count medium)${NC}"
else
  echo -e "${GREEN}PASS${NC}"
fi

# Verdict
echo "================================================"
TOTAL=$((CRITICAL_COUNT + HIGH_COUNT + MEDIUM_COUNT))

if [ "$CRITICAL_COUNT" -gt 0 ]; then
  echo -e "${RED}BLOCKED: $CRITICAL_COUNT CRITICAL findings detected.${NC}"
  echo -e "${RED}   Fix critical issues before pushing.${NC}"
  echo -e "${YELLOW}   Skip with: git push --no-verify (not recommended)${NC}"
  exit 1
elif [ "$TOTAL" -gt 0 ]; then
  echo -e "${YELLOW}WARNING: $TOTAL non-critical findings (H:$HIGH_COUNT M:$MEDIUM_COUNT)${NC}"
  echo -e "${YELLOW}   Push allowed. Run full scan to review: /security-reviewx${NC}"
  exit 0
else
  echo -e "${GREEN}PASS: No security findings detected.${NC}"
  exit 0
fi
