{
  "name": "agent-orchestration-protocol",
  "version": "4.3.0",
  "type": "orchestration-protocol",
  "status": "production-validated",
  "owner": "Claude Intelligence Hub",
  "description": "Multi-agent coordination framework — The Seven Pillars of AOP",
  "triggers": [
    "execute multi agent workflow",
    "aop workflow",
    "orchestrate",
    "delegate to",
    "headless agent",
    "multi-agent coordination"
  ],
  "dependencies": [],
  "settings": {
    "default_timeout": 840,
    "polling_interval": 60,
    "max_polls": 20,
    "headless_mode": true,
    "protocol_version": "aop_unified_v4"
  },
  "tier": "context-aware"
}
